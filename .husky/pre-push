#!/bin/sh

# Get the current branch
branch=$(git rev-parse --abbrev-ref HEAD)

# Only run QA tests when pushing to main
if [ "$branch" = "main" ]; then
  echo "Pushing to main - running QA rendering tests..."

  # Build and run rendering tests
  npm run qa

  if [ $? -ne 0 ]; then
    echo ""
    echo "QA tests failed! Push to main blocked."
    echo "Fix the rendering issues before pushing."
    exit 1
  fi

  echo "QA tests passed!"
fi
